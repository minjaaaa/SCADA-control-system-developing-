<Window x:Class="ScadaGUI.AddAlarmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj Novi Alarm" Height="380" Width="420" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Content="Naziv alarma (ID):" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="txtAlarmName" Grid.Row="0" Grid.Column="1" Margin="5" Height="25"/>

        <Label Content="Izaberi AI Tag:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
        <ComboBox x:Name="cmbAiTags" Grid.Row="1" Grid.Column="1" Margin="5" Height="25" DisplayMemberPath="Name"/>

        <Label Content="Tip alarma (Smer):" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
        <ComboBox x:Name="cmbAlarmType" Grid.Row="2" Grid.Column="1" Margin="5" Height="25">
            <ComboBoxItem Content="HIGH (Iznad granice)"/>
            <ComboBoxItem Content="LOW (Ispod granice)"/>
        </ComboBox>

        <Label Content="Granica (Limit):" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="txtLimit" Grid.Row="3" Grid.Column="1" Margin="5" Height="25"/>

        <Label Content="Poruka alarma:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="txtMessage" Grid.Row="4" Grid.Column="1" Margin="5" Height="25"/>

        <TextBlock x:Name="txtErrorBlock" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" 
                   Foreground="Red" TextWrapping="Wrap" HorizontalAlignment="Center" FontWeight="Bold"/>

        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button Content="Otkaži" Width="80" Height="30" Margin="5" Click="Cancel_Click"/>
            <Button Content="Sačuvaj" Width="100" Height="30" Margin="5" Click="Save_Click" Background="#FF1B75BC" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>