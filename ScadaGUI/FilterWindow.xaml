<Window x:Class="ScadaGUI.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filtriranje Tagova" Height="500" Width="600" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Parametri za filtriranje" Grid.Row="0" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Label Content="Ime taga (AI):" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbTags" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Margin="5" Height="25" DisplayMemberPath="Name"/>

                <Label Content="Vreme OD:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtTimeFrom" Grid.Row="1" Grid.Column="1" Margin="5" Height="25" ToolTip="Format: yyyy-MM-dd HH:mm:ss"/>

                <Label Content="Vreme DO:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"/>
                <TextBox x:Name="txtTimeTo" Grid.Row="1" Grid.Column="3" Margin="5" Height="25" ToolTip="Format: yyyy-MM-dd HH:mm:ss"/>

                <Label Content="Vrednost OD:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtValFrom" Grid.Row="2" Grid.Column="1" Margin="5" Height="25"/>

                <Label Content="Vrednost DO:" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center"/>
                <TextBox x:Name="txtValTo" Grid.Row="2" Grid.Column="3" Margin="5" Height="25"/>
            </Grid>
        </GroupBox>

        <Button Content="Pretraži" Grid.Row="1" Width="100" Height="30" HorizontalAlignment="Right" Margin="0,0,0,10" Click="Search_Click"/>

        <DataGrid x:Name="dataGridResults" Grid.Row="2" AutoGenerateColumns="True" IsReadOnly="True" Margin="0,0,0,10"/>

        <Button Content="Generate TXT" Grid.Row="3" Width="120" Height="35" HorizontalAlignment="Right" 
                Background="#FF1B75BC" Foreground="White" FontWeight="Bold" Click="GenerateTxt_Click"/>
    </Grid>
</Window>