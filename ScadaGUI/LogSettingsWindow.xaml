<Window x:Class="ScadaGUI.LogSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trace Bits Podešavanja" Height="274" Width="313" WindowStartupLocation="CenterOwner" Loaded="Window_Loaded">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="Izaberite događaje za logovanje:" FontWeight="Bold" Margin="0,0,0,10"/>

            <CheckBox x:Name="chkAppStart" Content="Pokretanje aplikacije" Margin="0,5"/>
            <CheckBox x:Name="chkAlarms" Content="Aktivacija/ACK Alarma" Margin="0,5"/>
            <CheckBox x:Name="chkTagManagement" Content="Dodavanje/Brisanje Tagova" Margin="0,5"/>
            <CheckBox x:Name="chkImportExport" Content="Import/Export JSON" Margin="0,5"/>
            <CheckBox x:Name="chkErrors" Content="Greške i Izuzeci" Margin="0,5"/>

            <Button Content="Sačuvaj TraceWord" Width="130" Height="30" Margin="0,15,0,0" 
                    Background="#FF1B75BC" Foreground="White" FontWeight="Bold" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>